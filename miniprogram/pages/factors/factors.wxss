.page-scroll {
  height: 100vh;
}

/* ── Tab Bar ── */
.tab-bar {
  display: flex;
  background: rgba(17, 24, 39, 0.8);
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #9CA3AF;
}

.tab-active {
  background: rgba(245, 158, 11, 0.15);
  color: #F59E0B;
  font-weight: 600;
}

/* ── Factor Cards ── */
.factor-card {
  background: linear-gradient(135deg, #111827 0%, #1F2937 100%);
  border: 1rpx solid rgba(75, 85, 99, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.factor-id-badge {
  background: rgba(245, 158, 11, 0.15);
  border: 1rpx solid rgba(245, 158, 11, 0.3);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}

.factor-id-badge text {
  font-size: 22rpx;
  font-weight: 700;
  color: #F59E0B;
}

/* ── Z-Score Bar ── */
.zscore-bar {
  height: 12rpx;
  background: rgba(75, 85, 99, 0.2);
  border-radius: 6rpx;
  position: relative;
  overflow: hidden;
}

.zscore-center-line {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: rgba(156, 163, 175, 0.4);
}

.zscore-fill {
  position: absolute;
  top: 0;
  height: 100%;
  border-radius: 6rpx;
  max-width: 50%;
}

.zscore-fill.positive {
  left: 50%;
}

.zscore-fill.negative {
  right: 50%;
}

/* ══════════════════════════════ */
/* ── IC Tracking Styles ──      */
/* ══════════════════════════════ */
.ic-stats-grid {
  display: flex;
  gap: 12rpx;
}

.ic-stat-card {
  flex: 1;
  background: linear-gradient(135deg, #111827 0%, #1F2937 100%);
  border: 1rpx solid rgba(75, 85, 99, 0.3);
  border-radius: 14rpx;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ic-stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

.ic-stat-value {
  font-size: 32rpx;
  font-weight: 700;
}

/* ── IC Bar Chart ── */
.ic-chart {
  overflow: hidden;
}

.ic-chart-area {
  display: flex;
  align-items: center;
  height: 200rpx;
  gap: 2rpx;
}

.ic-bar-wrapper {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ic-bar-pos {
  min-height: 4rpx;
  width: 100%;
  border-radius: 2rpx 2rpx 0 0;
  align-self: flex-end;
}

.ic-zero-line {
  width: 100%;
  height: 1rpx;
  background: rgba(156, 163, 175, 0.3);
}

.ic-bar-neg {
  min-height: 4rpx;
  width: 100%;
  border-radius: 0 0 2rpx 2rpx;
  align-self: flex-start;
}

.ic-x-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.ic-x-label {
  font-size: 18rpx;
  color: #6B7280;
}

/* ── IC Data Table ── */
.ic-table {
  display: flex;
  flex-direction: column;
}

.ic-table-header {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(75, 85, 99, 0.3);
}

.ic-table-header .ic-col {
  font-size: 22rpx;
  color: #6B7280;
  font-weight: 600;
}

.ic-table-row {
  display: flex;
  padding: 8rpx 0;
  border-bottom: 1rpx solid rgba(75, 85, 99, 0.1);
  align-items: center;
}

.ic-col {
  flex: 1;
  font-size: 24rpx;
  text-align: center;
}

.ic-col:first-child {
  text-align: left;
}

.ic-col:last-child {
  text-align: right;
}

/* ══════════════════════════════ */
/* ── Regime Heatmap Styles ──   */
/* ══════════════════════════════ */
.heatmap-card {
  padding: 16rpx;
}

.heatmap-scroll {
  width: 100%;
}

.heatmap-table {
  display: flex;
  flex-direction: column;
  min-width: 700rpx;
}

.hm-row {
  display: flex;
  gap: 2rpx;
  margin-bottom: 2rpx;
}

.hm-header {
  margin-bottom: 4rpx;
}

.hm-cell {
  flex: 1;
  min-width: 64rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4rpx;
}

.hm-month-cell {
  min-width: 72rpx;
  flex: none;
  justify-content: flex-start;
  padding-left: 4rpx;
}

.hm-factor-label {
  font-size: 18rpx;
  color: #9CA3AF;
  font-weight: 600;
}

.hm-value {
  font-size: 20rpx;
  font-weight: 500;
}

/* ── Color Legend ── */
.legend-row {
  display: flex;
  justify-content: space-between;
}

.legend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.legend-swatch {
  width: 40rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

/* ── Description List ── */
.desc-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.desc-item {
  font-size: 24rpx;
  color: #D1D5DB;
  line-height: 1.6;
}
