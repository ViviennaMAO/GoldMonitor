.page-scroll {
  height: 100vh;
}

/* ── Price Card ── */
.price-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

/* ── Signal Card ── */
.signal-card {
  background: linear-gradient(135deg, #111827 0%, #1a2332 100%);
}

/* ── SHAP List ── */
.shap-item {
  margin-bottom: 16rpx;
}

.shap-item:last-child {
  margin-bottom: 0;
}

/* ── Factor Mini Grid ── */
.factor-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.factor-mini {
  width: calc(33.33% - 8rpx);
  background: rgba(17, 24, 39, 0.8);
  border: 1rpx solid rgba(75, 85, 99, 0.2);
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.factor-mini-name {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-bottom: 6rpx;
  text-align: center;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  max-width: 100%;
}

.factor-mini-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #F9FAFB;
  margin-bottom: 4rpx;
}

.factor-mini-zscore {
  font-size: 20rpx;
  font-weight: 500;
}
