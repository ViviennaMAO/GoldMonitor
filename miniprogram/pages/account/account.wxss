.page-scroll {
  height: 100vh;
}

/* ── Balance Card ── */
.balance-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.balance-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.balance-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: #F59E0B;
  margin-top: 8rpx;
}

/* ── Performance Grid ── */
.perf-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 2rpx;
}

.perf-item {
  width: calc(50% - 1rpx);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 12rpx;
  background: rgba(17, 24, 39, 0.4);
  border-radius: 8rpx;
}

.perf-label {
  font-size: 24rpx;
  color: #9CA3AF;
}

.perf-value {
  font-size: 26rpx;
  font-weight: 600;
}

/* ── Risk Legend ── */
.risk-legend {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── Info List ── */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(75, 85, 99, 0.15);
}

.info-row:last-child {
  border-bottom: none;
}

/* ── Refresh Button ── */
.refresh-btn {
  margin: 24rpx 0 40rpx;
  padding: 20rpx;
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.3);
  border-radius: 12rpx;
  text-align: center;
  color: #F59E0B;
  font-size: 28rpx;
  font-weight: 600;
}

.refresh-btn:active {
  opacity: 0.7;
}
