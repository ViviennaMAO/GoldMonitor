.page-scroll {
  height: 100vh;
}

/* ── Balance Card ── */
.balance-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.balance-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.balance-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: #F59E0B;
  margin-top: 8rpx;
}

/* ── Account Grid ── */
.account-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.account-item {
  width: calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}

.account-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 6rpx;
}

.account-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #F9FAFB;
}

/* ── PnL Grid ── */
.pnl-grid {
  display: flex;
  gap: 16rpx;
}

.pnl-item {
  flex: 1;
  background: rgba(17, 24, 39, 0.6);
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pnl-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

.pnl-value {
  font-size: 32rpx;
  font-weight: 700;
}

/* ── Risk Grid ── */
.risk-grid {
  display: flex;
  gap: 12rpx;
}

.risk-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.risk-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.risk-value {
  font-size: 28rpx;
  font-weight: 700;
}

/* ── Risk Legend ── */
.risk-legend {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── Info List ── */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(75, 85, 99, 0.15);
}

.info-row:last-child {
  border-bottom: none;
}

/* ── Refresh Button ── */
.refresh-btn {
  margin: 24rpx 0 40rpx;
  padding: 20rpx;
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.3);
  border-radius: 12rpx;
  text-align: center;
  color: #F59E0B;
  font-size: 28rpx;
  font-weight: 600;
}

.refresh-btn:active {
  opacity: 0.7;
}
