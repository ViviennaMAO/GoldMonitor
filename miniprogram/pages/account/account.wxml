<!-- Account Page -->
<scroll-view scroll-y class="page-scroll">
  <view class="container">

    <!-- ── Account Balance Card ── -->
    <view class="card balance-card">
      <view class="row-between mb-12">
        <text class="card-title">VSTAR 仿真账户</text>
        <view class="badge {{regimeClass}}">
          <text>{{regimeStatus}} {{riskMultiplier}}</text>
        </view>
      </view>

      <view class="balance-main">
        <text class="text-xs text-gray">账户权益</text>
        <text class="balance-amount">{{finalEquity}}</text>
        <text class="text-sm mt-8" style="color: {{totalReturnColor}}">总收益 {{totalReturn}}</text>
      </view>
    </view>

    <!-- ── Performance Stats ── -->
    <view class="card">
      <text class="card-title">策略表现</text>
      <view class="perf-grid mt-12">
        <view class="perf-item">
          <text class="perf-label">初始资金</text>
          <text class="perf-value text-white">{{initialEquity}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">最终权益</text>
          <text class="perf-value text-green">{{finalEquity}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">Sharpe 比率</text>
          <text class="perf-value text-gold">{{sharpe}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">最大回撤</text>
          <text class="perf-value text-red">{{maxDrawdown}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">交易次数</text>
          <text class="perf-value text-white">{{totalTrades}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">胜率</text>
          <text class="perf-value text-gold">{{winRate}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">盈利/亏损</text>
          <text class="perf-value">
            <text class="text-green">{{winners}}</text>
            <text class="text-gray"> / </text>
            <text class="text-red">{{losers}}</text>
          </text>
        </view>
        <view class="perf-item">
          <text class="perf-label">平均盈/亏</text>
          <text class="perf-value">
            <text class="text-green">{{avgWin}}</text>
            <text class="text-gray"> / </text>
            <text class="text-red">{{avgLoss}}</text>
          </text>
        </view>
      </view>
    </view>

    <!-- ── Active Position ── -->
    <view class="card" wx:if="{{activePosition}}">
      <view class="row-between mb-12">
        <text class="card-title">当前持仓</text>
        <view class="badge {{activePosition.dirClass}}">
          <text>{{activePosition.direction}}</text>
        </view>
      </view>
      <view class="perf-grid">
        <view class="perf-item">
          <text class="perf-label">品种</text>
          <text class="perf-value text-gold">{{activePosition.symbol}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">手数</text>
          <text class="perf-value text-white">{{activePosition.size}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">入场价</text>
          <text class="perf-value text-white">${{activePosition.entryPrice}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">现价</text>
          <text class="perf-value text-white">${{activePosition.currentPrice}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">止损</text>
          <text class="perf-value text-red">${{activePosition.stopLoss}}</text>
        </view>
        <view class="perf-item">
          <text class="perf-label">浮盈</text>
          <text class="perf-value" style="color: {{activePosition.pnlColor}}">{{activePosition.pnl}}</text>
        </view>
      </view>
    </view>

    <!-- ── Risk Regime Card ── -->
    <view class="card">
      <text class="card-title">风险管理</text>
      <view class="risk-legend mt-12">
        <view class="legend-item">
          <view class="legend-dot" style="background: #10B981;"></view>
          <text class="text-xs text-gray">Risk-On (1.0x) — 正常仓位</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot" style="background: #F59E0B;"></view>
          <text class="text-xs text-gray">Transition (0.5x) — 减半仓位</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot" style="background: #EF4444;"></view>
          <text class="text-xs text-gray">Risk-Off (0x) — 禁止开仓</text>
        </view>
      </view>
    </view>

    <!-- ── App Info Card ── -->
    <view class="card">
      <text class="card-title">系统信息</text>
      <view class="info-list mt-12">
        <view class="info-row">
          <text class="text-sm text-gray">版本</text>
          <text class="text-sm text-white">{{version}}</text>
        </view>
        <view class="info-row">
          <text class="text-sm text-gray">数据源</text>
          <text class="text-sm text-white">FRED + Yahoo + Stooq</text>
        </view>
        <view class="info-row" bindtap="onCopyApi">
          <text class="text-sm text-gray">API 地址</text>
          <text class="text-sm text-gold">点击复制</text>
        </view>
      </view>
    </view>

    <!-- Refresh button -->
    <view class="refresh-btn" bindtap="onRefreshTap">
      <text>刷新数据</text>
    </view>

  </view>
</scroll-view>
