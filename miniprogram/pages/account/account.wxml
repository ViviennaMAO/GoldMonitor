<!-- Account Page -->
<scroll-view scroll-y class="page-scroll">
  <view class="container">

    <!-- ── Account Balance Card ── -->
    <view class="card balance-card">
      <view class="row-between mb-12">
        <text class="card-title">VSTAR 仿真账户</text>
        <view class="badge {{regimeClass}}">
          <text>{{regimeStatus}}</text>
        </view>
      </view>

      <view class="balance-main">
        <text class="text-xs text-gray">账户权益</text>
        <text class="balance-amount">{{equity}}</text>
      </view>

      <view class="divider"></view>

      <view class="account-grid">
        <view class="account-item">
          <text class="account-label">余额</text>
          <text class="account-value">{{balance}}</text>
        </view>
        <view class="account-item">
          <text class="account-label">已用保证金</text>
          <text class="account-value">{{margin}}</text>
        </view>
        <view class="account-item">
          <text class="account-label">可用保证金</text>
          <text class="account-value">{{freeMargin}}</text>
        </view>
        <view class="account-item">
          <text class="account-label">保证金率</text>
          <text class="account-value">{{marginLevel}}</text>
        </view>
      </view>
    </view>

    <!-- ── P&L Card ── -->
    <view class="card">
      <text class="card-title">盈亏表现</text>
      <view class="pnl-grid mt-12">
        <view class="pnl-item">
          <text class="pnl-label">今日盈亏</text>
          <text class="pnl-value" style="color: {{todayPnlColor}}">{{todayPnl}}</text>
        </view>
        <view class="pnl-item">
          <text class="pnl-label">本周盈亏</text>
          <text class="pnl-value" style="color: {{weekPnlColor}}">{{weekPnl}}</text>
        </view>
      </view>
    </view>

    <!-- ── Risk Regime Card ── -->
    <view class="card">
      <text class="card-title">风险管理</text>
      <view class="risk-grid mt-12">
        <view class="risk-item">
          <text class="risk-label">风控状态</text>
          <view class="badge {{regimeClass}}">
            <text>{{regimeStatus}}</text>
          </view>
        </view>
        <view class="risk-item">
          <text class="risk-label">仓位乘数</text>
          <text class="risk-value text-gold">{{riskMultiplier}}</text>
        </view>
        <view class="risk-item">
          <text class="risk-label">持仓数量</text>
          <text class="risk-value text-white">{{openCount}}</text>
        </view>
      </view>

      <!-- Risk level explanation -->
      <view class="risk-legend mt-16">
        <view class="legend-item">
          <view class="legend-dot" style="background: #10B981;"></view>
          <text class="text-xs text-gray">健康 (1.0×) — 正常仓位</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot" style="background: #F59E0B;"></view>
          <text class="text-xs text-gray">警戒 (0.5×) — 减半仓位</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot" style="background: #EF4444;"></view>
          <text class="text-xs text-gray">熔断 (0×) — 禁止开仓</text>
        </view>
      </view>
    </view>

    <!-- ── App Info Card ── -->
    <view class="card">
      <text class="card-title">系统信息</text>
      <view class="info-list mt-12">
        <view class="info-row">
          <text class="text-sm text-gray">版本</text>
          <text class="text-sm text-white">{{version}}</text>
        </view>
        <view class="info-row">
          <text class="text-sm text-gray">数据源</text>
          <text class="text-sm text-white">FRED + Stooq</text>
        </view>
        <view class="info-row" bindtap="onCopyApi">
          <text class="text-sm text-gray">API 地址</text>
          <text class="text-sm text-gold">点击复制</text>
        </view>
      </view>
    </view>

    <!-- Refresh button -->
    <view class="refresh-btn" bindtap="onRefreshTap">
      <text>刷新数据</text>
    </view>

  </view>
</scroll-view>
