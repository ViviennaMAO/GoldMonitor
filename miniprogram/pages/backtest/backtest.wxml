<!-- Backtest Page -->
<scroll-view scroll-y class="page-scroll">
  <view class="container">

    <!-- ── Tab Switcher ── -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'overview' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="overview">
        <text>回测概览</text>
      </view>
      <view class="tab-item {{activeTab === 'trades' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="trades">
        <text>交易记录</text>
      </view>
      <view class="tab-item {{activeTab === 'equity' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="equity">
        <text>权益曲线</text>
      </view>
    </view>

    <!-- ══════════════════════════════════════ -->
    <!-- ── Overview Tab ── -->
    <!-- ══════════════════════════════════════ -->
    <view wx:if="{{activeTab === 'overview'}}">
      <!-- Stats Grid -->
      <view class="stats-grid">
        <view class="stat-card">
          <text class="stat-label">总收益率</text>
          <text class="stat-value" style="color: {{totalReturnColor}}">{{totalReturn}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">最大回撤</text>
          <text class="stat-value text-red">{{maxDrawdown}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">胜率</text>
          <text class="stat-value text-gold">{{winRate}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">交易次数</text>
          <text class="stat-value text-white">{{tradeCount}}</text>
        </view>
        <view class="stat-card stat-card-wide">
          <text class="stat-label">最终权益</text>
          <text class="stat-value text-green">{{finalEquity}}</text>
        </view>
      </view>

      <!-- Active Position -->
      <view class="card mt-20" wx:if="{{activePosition}}">
        <view class="row-between mb-12">
          <text class="card-title">当前持仓</text>
          <view class="badge {{activePosition.dirClass}}">
            <text>{{activePosition.direction}}</text>
          </view>
        </view>
        <view class="pos-grid">
          <view class="pos-item">
            <text class="pos-label">品种</text>
            <text class="pos-value text-gold">{{activePosition.symbol}}</text>
          </view>
          <view class="pos-item">
            <text class="pos-label">手数</text>
            <text class="pos-value text-white">{{activePosition.size}}</text>
          </view>
          <view class="pos-item">
            <text class="pos-label">入场价</text>
            <text class="pos-value text-white">${{activePosition.entryPrice}}</text>
          </view>
          <view class="pos-item">
            <text class="pos-label">现价</text>
            <text class="pos-value text-white">${{activePosition.currentPrice}}</text>
          </view>
          <view class="pos-item">
            <text class="pos-label">止损</text>
            <text class="pos-value text-red">${{activePosition.stopLoss}}</text>
          </view>
          <view class="pos-item">
            <text class="pos-label">浮盈</text>
            <text class="pos-value" style="color: {{activePosition.pnlColor}}">{{activePosition.pnl}} ({{activePosition.pnlPercent}})</text>
          </view>
        </view>
      </view>

      <!-- Strategy Description -->
      <view class="card mt-20">
        <text class="card-title">策略说明</text>
        <view class="desc-list mt-12">
          <text class="desc-item">模型: XGBoost Regressor (max_depth=4)</text>
          <text class="desc-item">目标: 20日远期 XAU/USD 收益率</text>
          <text class="desc-item">信号: 预测收益 +0.8%以上强买, -0.8%以下强卖</text>
          <text class="desc-item">止损: 2.5x ATR (14日)</text>
          <text class="desc-item">仓位: ATR 风险预算 2%</text>
          <text class="desc-item">训练期: 2015-2022, 测试期: 2023+</text>
        </view>
      </view>
    </view>

    <!-- ══════════════════════════════════════ -->
    <!-- ── Trades Tab ── -->
    <!-- ══════════════════════════════════════ -->
    <view wx:if="{{activeTab === 'trades'}}">
      <view class="trade-card" wx:for="{{trades}}" wx:key="date">
        <view class="row-between mb-8">
          <view class="row" style="gap: 12rpx;">
            <view class="badge {{item.dirClass}}">
              <text>{{item.direction}}</text>
            </view>
            <text class="text-sm text-gray">{{item.date}}</text>
          </view>
          <text class="text-sm text-bold" style="color: {{item.pnlColor}}">{{item.pnlPercent}}</text>
        </view>
        <view class="row-between">
          <text class="text-xs text-gray">入场: ${{item.entryPrice}}</text>
          <text class="text-xs text-gray">出场: ${{item.exitPrice}}</text>
          <text class="text-xs" style="color: {{item.pnlColor}}">{{item.pnl}}</text>
        </view>
      </view>

      <view wx:if="{{trades.length === 0}}" class="text-center mt-20">
        <text class="text-gray">暂无交易记录</text>
      </view>
    </view>

    <!-- ══════════════════════════════════════ -->
    <!-- ── Equity Tab ── -->
    <!-- ══════════════════════════════════════ -->
    <view wx:if="{{activeTab === 'equity'}}">
      <view class="card">
        <text class="card-title">权益变化 (采样)</text>
        <view class="equity-table mt-12">
          <view class="equity-header">
            <text class="eq-col">日期</text>
            <text class="eq-col">权益</text>
            <text class="eq-col">回撤</text>
          </view>
          <view class="equity-row" wx:for="{{equityPoints}}" wx:key="date">
            <text class="eq-col text-gray">{{item.date}}</text>
            <text class="eq-col text-white">{{item.equity}}</text>
            <text class="eq-col" style="color: {{item.drawdownColor}}">{{item.drawdown}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{equityPoints.length === 0}}" class="text-center mt-20">
        <text class="text-gray">暂无权益数据</text>
      </view>
    </view>

  </view>
</scroll-view>
