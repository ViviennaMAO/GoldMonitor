.page-scroll {
  height: 100vh;
}

/* ── Tab Bar ── */
.tab-bar {
  display: flex;
  background: rgba(17, 24, 39, 0.8);
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #9CA3AF;
}

.tab-active {
  background: rgba(245, 158, 11, 0.15);
  color: #F59E0B;
  font-weight: 600;
}

/* ── Stats Grid ── */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.stat-card {
  width: calc(50% - 6rpx);
  background: linear-gradient(135deg, #111827 0%, #1F2937 100%);
  border: 1rpx solid rgba(75, 85, 99, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-card-wide {
  width: 100%;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

/* ── Active Position ── */
.pos-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pos-item {
  width: calc(50% - 6rpx);
  display: flex;
  flex-direction: column;
  padding: 8rpx 0;
}

.pos-label {
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 4rpx;
}

.pos-value {
  font-size: 28rpx;
  font-weight: 600;
}

/* ── Strategy Description ── */
.desc-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.desc-item {
  font-size: 24rpx;
  color: #D1D5DB;
  line-height: 1.6;
}

/* ── Trade Cards ── */
.trade-card {
  background: linear-gradient(135deg, #111827 0%, #1F2937 100%);
  border: 1rpx solid rgba(75, 85, 99, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

/* ── Equity Table ── */
.equity-table {
  display: flex;
  flex-direction: column;
}

.equity-header {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(75, 85, 99, 0.3);
}

.equity-header .eq-col {
  font-size: 22rpx;
  color: #6B7280;
  font-weight: 600;
}

.equity-row {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(75, 85, 99, 0.1);
}

.eq-col {
  flex: 1;
  font-size: 24rpx;
  text-align: center;
}

.eq-col:first-child {
  text-align: left;
}

.eq-col:last-child {
  text-align: right;
}
